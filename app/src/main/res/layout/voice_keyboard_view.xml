<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/keyboard_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground"
    android:elevation="8dp"
    android:outlineProvider="bounds">

    <!-- Barra de Estado / Feedback (Oculta por defecto) -->
    <LinearLayout
        android:id="@+id/statusContainer"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="#FAFAFA"
        android:visibility="gone"
        android:alpha="0">

        <ImageView
            android:id="@+id/ivWaveform"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_mic"
            android:contentDescription="Estado"/>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Escuchando..."
            android:textColor="#333333"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:visibility="gone"
            android:indeterminateTint="#FF9800"/>
    </LinearLayout>

    <!-- Fila Superior: Espacio + Micrófono Grande + Borrar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center">

        <!-- Botón Espacio -->
        <ImageButton
            android:id="@+id/btnSpace"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="3"
            android:src="@drawable/ic_space"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Espacio"
            app:tint="#555555"/>

        <!-- Contenedor Botón Micrófono (Con fondo circular) -->
        <FrameLayout
            android:id="@+id/btnMicContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:layout_marginHorizontal="12dp"
            android:background="@drawable/bg_mic_circle"
            android:clickable="true"
            android:focusable="true">

            <ImageButton
                android:id="@+id/btnMic"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_mic"
                android:contentDescription="Grabar voz"
                app:tint="#FFFFFF"/>
        </FrameLayout>

        <!-- Botón Borrar -->
        <ImageButton
            android:id="@+id/btnBackspace"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.5"
            android:src="@drawable/ic_backspace"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Borrar"
            app:tint="#D32F2F"/>
    </LinearLayout>

    <!-- Fila Inferior: Ajustes + Cambio Idioma + Enter -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:gravity="center">

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Ajustes"
            app:tint="#757575"/>

        <Button
            android:id="@+id/btnLanguage"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="2"
            android:text="🌐 Auto"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:background="@drawable/bg_button_rounded"
            android:backgroundTint="#E3F2FD"
            android:textColor="#1565C0"/>

        <ImageButton
            android:id="@+id/btnEnter"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.5"
            android:src="@drawable/ic_enter"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Enter"
            app:tint="#2E7D32"/>
    </LinearLayout>
</LinearLayout>