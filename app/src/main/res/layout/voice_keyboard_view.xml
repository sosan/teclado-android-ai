<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/keyboard_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground"
    android:elevation="8dp">

    <!-- Barra de Estado / Feedback -->
    <LinearLayout
        android:id="@+id/status_bar"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="#F5F5F5"
        android:visibility="gone">

        <ImageView
            android:id="@+id/status_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_mic"
            app:tint="#D32F2F"/>

        <TextView
            android:id="@+id/status_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Escuchando..."
            android:textColor="#333333"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <ProgressBar
            android:id="@+id/processing_indicator"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Fila Superior: Espacio + Micrófono Grande + Borrar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:padding="4dp">

        <!-- Botón Espacio (Inserta espacio rápido) -->
        <Button
            android:id="@+id/btn_space"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="3"
            android:text="Espacio"
            android:textSize="16sp"
            android:backgroundTint="#E0E0E0"
            android:textColor="#424242"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <!-- Botón Micrófono (PRINCIPAL) -->
        <FrameLayout
            android:id="@+id/btn_mic_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/mic_button_bg"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:id="@+id/btn_mic"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_mic"
                app:tint="#FFFFFF"/>
        </FrameLayout>

        <!-- Botón Borrar -->
        <ImageButton
            android:id="@+id/btn_delete"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.5"
            android:src="@drawable/ic_backspace"
            android:backgroundTint="#FFEBEE"
            app:tint="#D32F2F"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
    </LinearLayout>

    <!-- Fila Inferior: Ajustes + Cambio Idioma + Enter -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:padding="4dp">

        <ImageButton
            android:id="@+id/btn_settings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#757575"/>

        <Button
            android:id="@+id/btn_language"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:text="ES/CA"
            android:textSize="12sp"
            android:backgroundTint="#E3F2FD"
            android:textColor="#1565C0"/>

        <ImageButton
            android:id="@+id/btn_enter"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.5"
            android:src="@drawable/ic_enter"
            android:backgroundTint="#E8F5E9"
            app:tint="#2E7D32"/>
    </LinearLayout>
</LinearLayout>
